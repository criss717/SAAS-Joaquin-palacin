generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  USER
}

enum TaskStatus {
  APROBADO
  EN_PROCESO
  CAMBIOS_SOLICITADOS
  HECHO
  CANCELADO
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  passwordHash    String
  role            Role           @default(USER)
  taskAssignments TaskAssignee[]
}

model Project {
  id        String   @id @default(uuid())
  name      String
  stage     String   @default("Planeación") // estado global del proyecto
  createdAt DateTime @default(now())
  tasks     Task[]
  stages    Stage[]  // columnas Kanban del proyecto
}

model Task {
  id           String   @id @default(uuid())
  name         String
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  parentId     String?
  parent       Task?    @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks     Task[]   @relation("SubTasks")
  
  isAssembly   Boolean        @default(false)
  stage        String         @default("Pendiente")
  status       TaskStatus     @default(EN_PROCESO)
  progress     Int            @default(0)
  
  assignees    TaskAssignee[]  // Múltiples operarios asignados
  
  estimatedHours Float?         @default(8) // Evolución a ERP por horas
  startDate    DateTime
  endDate      DateTime
  
  predecessors TaskDependency[] @relation("SuccessorTasks")
  successors   TaskDependency[] @relation("PredecessorTasks")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TaskDependency {
  id            String @id @default(uuid())
  predecessorId String
  successorId   String
  
  predecessor   Task   @relation("PredecessorTasks", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor     Task   @relation("SuccessorTasks", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId])
}

/** Tabla de asignación múltiple: tarea ↔ operarios */
model TaskAssignee {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

/** Etapas (columnas) dinámicas del tablero Kanban por proyecto */
model Stage {
  id        String  @id @default(uuid())
  name      String
  color     String  @default("#94a3b8") // color hex para el borde superior de la columna
  order     Int     @default(0)          // posición en el tablero
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
}

// ----------------------------------------------------------------------
// MÓDULO DE CATÁLOGO / INGENIERÍA (BOM)
// ----------------------------------------------------------------------

/** 
 * Máquina o Producto Teórico (Ej: Decanter P6)
 * Actúa como la base o plantilla para crear un Proyecto.
 */
model MachineCatalog {
  id          String   @id @default(uuid())
  name        String   
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parts       CatalogPart[]
}

/** 
 * Pieza o Ensamble del Catálogo (Ej: Rotor, Sinfín, Eje, Chasis)
 * Al lanzarse a producción, se convierten en Task con isAssembly = true.
 */
model CatalogPart {
  id          String   @id @default(uuid())
  name        String   
  machineId   String
  machine     MachineCatalog @relation(fields: [machineId], references: [id], onDelete: Cascade)
  
  parentId    String?
  parent      CatalogPart?   @relation("CatalogSubParts", fields: [parentId], references: [id], onDelete: Cascade)
  subParts    CatalogPart[]  @relation("CatalogSubParts")
  
  quantity    Int            @default(1) 
  
  operations  CatalogOperation[]
}

/** 
 * Tarea operativa estándar (Ej: Soldar Virola, Torno)
 * Al lanzarse a producción, se convierten en Task con isAssembly = false.
 */
model CatalogOperation {
  id             String   @id @default(uuid())
  name           String   
  partId         String
  part           CatalogPart @relation(fields: [partId], references: [id], onDelete: Cascade)
  
  estimatedHours Float    @default(8)   // Evolución a ERP para medir con precisión
  orderIndex     Int      @default(0)
}

// ----------------------------------------------------------------------
// MÓDULO DE RECURSOS HUMANOS / CONTROL DE HORARIOS DE TRABAJO
// ----------------------------------------------------------------------

/**
 * Temporadas de horario de planta (ej. Invierno vs Verano).
 * Permite que el Gantt sepa cuántas horas tiene un día.
 */
model WorkSchedule {
  id          String   @id @default(uuid())
  name        String   // Ej: "Horario Verano 2026"
  validFrom   DateTime // Fecha de inicio de validez
  validUntil  DateTime // Fecha de fin de validez
  workingDays String   @default("[1,2,3,4,5]") // JSON array e.g. 1=Lun
  shifts      String   @default("[{\"start\": \"08:00\", \"end\": \"14:00\"}, {\"start\": \"16:00\", \"end\": \"18:00\"}]") // Json 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/**
 * Días festivos (Ferias, Navidades) de un año. 
 * El calculador de Gantt los saltará.
 */
model Holiday {
  id          String   @id @default(uuid())
  name        String   // Ej: "Feria de Abril"
  startDate   DateTime // Inicio del festivo
  endDate     DateTime? // Fin del festivo (opcional, si es de un solo día)
  createdAt   DateTime @default(now())
}
